# ----------------------------------------------------------------------------
# web3compass-sns-indexer — environment template
#
# Copy to `.env` and fill in. `.env` is gitignored. NEVER commit secrets.
# Schema lives in web3compassapi; this service runs migrations: false.
# ----------------------------------------------------------------------------

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# ---------------- Database (shared with web3compassapi) ----------------------
# Point at the same Postgres web3compassapi's migrations ran against.
# Required: AddSnsSupport1777881600000 must be applied before this service
# starts, or jobs will crash on missing enum values.
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
PG_SSL=true

# ---------------- Solana RPC -------------------------------------------------
# Two ways to configure (in order of precedence):
#
# 1. Explicit URL (escape hatch — useful for QuickNode, Triton, devnet, etc.)
#    Takes precedence over provider+key. Set this to override everything.
# SOLANA_RPC_URL=
#
# 2. Provider + API key (preferred for prod). Builds the URL from a
#    well-known template. Switch providers by changing SOLANA_RPC_PROVIDER.
#    Supported: alchemy | helius
#    Networks:  mainnet (default) | devnet
#
# Production: alchemy (paid). Backfill uses single-shot getProgramAccounts;
# steady-state uses signature-walks + per-domain reverse-lookups.
SOLANA_RPC_PROVIDER=alchemy
SOLANA_RPC_API_KEY=
SOLANA_RPC_NETWORK=mainnet

# Process-wide cap on outbound Solana RPS. Token-bucket throttle covers
# both our direct calls and the ones the Bonfida SDK makes internally.
# Tuning notes:
#   - 10  : free-tier safe (default)
#   - 25  : moderate, recommended for paid Alchemy steady-state
#   - 50+ : burst-friendly; only if your plan documents sustained headroom
# SOLANA_RPC_MAX_RPS=25

# Per-tick concurrency caps (PromisePool workers). Defaults work for
# moderate-RPS plans; raise only if RPS budget allows.
# SNS_TX_FETCH_CONCURRENCY=2
# SNS_RESOLVE_CONCURRENCY=5

# ---------------- SNS cursor seeds (optional) --------------------------------
# Optional starting signatures for the signature-walk jobs. Leave empty
# on first run to seed from current head. Set to a known older signature
# to backfill recent history without running the full backfill job.
SNS_REGISTER_STARTED_SIGNATURE=
SNS_RECORDS_V2_STARTED_SIGNATURE=

# ---------------- Backfill (cron job) ----------------------------------------
# `true` enables the backfill cron, which incrementally enumerates every
# top-level `.sol` domain in 256 partitions (one per first-byte-of-owner)
# and inserts skeleton rows. Reconcile then drains them on its normal
# schedule. Each tick processes a few partitions, small payloads,
# retries on rate limits, holds cursor on errors.
#
# Once cursor reaches partition 256 the job marks `isMigrated=true` on
# the `SNS_BACKFILL` row in `dns_migrations` and never runs again until
# the row is reset manually. New domains registered after backfill
# completes are caught by `sns-register.job` going forward.
#
# Set to `true` for first prod boot; can stay true afterward (no-op once
# complete).
SNS_BACKFILL_ENABLED=true

# Partitions per tick. Each = ~3000 accounts on Alchemy single-shot
# `getProgramAccounts`. Default 2 ≈ 4h end-to-end on paid Alchemy.
# Raise to 4 (≈ 2h) only if you've watched a few ticks land green.
# SNS_BACKFILL_PARTITIONS_PER_TICK=2

# Reverse-lookup batch size (one `getMultipleAccountsInfo` call per batch,
# RPC-capped at 100 keys).
# SNS_BACKFILL_BATCH_SIZE=50

# ---------------- Cron master switch -----------------------------------------
# When `true`, the cron jobs (register / record-changes / reconcile /
# backfill) tick on their schedules. When `false`, the decorators are
# still registered with NestJS but every tick is a no-op — the indexer
# is idle. CLI runs (`yarn cli:once <job>`) bypass this gate, so smoke
# testing works regardless.
ENABLE_SNS_CRONS=true

# ---------------- IPFS gateway ----------------------------------------------
# Concatenated with `dns.cid` to compute the `ipfsUrl` audit value on
# `dns_settings`. Trailing slash required.
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
