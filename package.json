{
  "name": "web3compass-sns-indexer",
  "version": "0.1.0-dev",
  "private": true,
  "description": "Solana Name Service (.sol) indexer that writes into the shared web3compass Postgres database.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "ts-node src/main.ts",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/main.ts",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'scripts/**/*.ts'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:entities": "ts-node scripts/check-entity-drift.ts",
    "cli:once": "ts-node src/cli/run-once.ts"
  },
  "dependencies": {
    "@bonfida/spl-name-service": "^3.0.0",
    "@elastic/ecs-pino-format": "^1.5.0",
    "@nestjs/common": "^10.2.10",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.10",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.1.16",
    "@nestjs/typeorm": "^10.0.1",
    "@solana/web3.js": "^1.95.0",
    "@supercharge/promise-pool": "^2.3.2",
    "bs58": "^4.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.0.2",
    "nestjs-pino": "^3.5.0",
    "pg": "^8.7.3",
    "pino": "^8.16.0",
    "pino-http": "^8.5.1",
    "reflect-metadata": "^0.1.13",
    "rotating-file-stream": "^3.2.3",
    "rxjs": "^7.5.6",
    "typeorm": "^0.3.7",
    "typeorm-transactional": "^0.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-import-helpers": "^1.3.1",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-sonarjs": "^0.23.0",
    "eslint-plugin-unicorn": "^49.0.0",
    "nodemon": "^3.0.2",
    "pino-pretty": "^10.2.3",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
